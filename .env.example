NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
# Doctor licence tier Price IDs (Dashboard → Products → copy price_…)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_CLINIC=price_...
STRIPE_PRICE_EXTRA_SEAT=price_...
STRIPE_PRICE_TESTING_ADDON=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=MyDoctors360 <noreply@mydoctors360.com>

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_BUSINESS_NUMBER=+491234567890
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=+491234567890

# Support & Contact (use mydoctors360.com — not legacy mydoctor.com)
SUPPORT_EMAIL=support@mydoctors360.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@mydoctors360.com
CONTACT_ADMIN_EMAIL=sales@mydoctors360.com

# Cron Security
CRON_SECRET=your-cron-secret-here

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Admin Security — comma-separated list of allowed admin emails
ADMIN_EMAILS=you@yourcompany.com

# OpenAI (for AI features: symptom navigator, NL search, review summaries)
OPENAI_API_KEY=sk-...

# xAI Grok Voice (STT + TTS for floating mic / voice search)
# https://console.x.ai/ — create an API key with voice access
XAI_API_KEY=xai-...

# Pexels (free royalty-free image search for blog covers)
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_...

# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
