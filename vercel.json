{
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup-expired",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sync-calendars",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/treatment-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/satisfaction-surveys",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/verify-doctor-credentials",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|_next/|coming-soon|sitemap\\.xml|robots\\.txt|favicon\\.ico|manifest\\.json|.*\\.(?:svg|png|jpg|jpeg|gif|webp|ico|css|js|woff|woff2|ttf|map)$|(?:en|de|tr|fr|it|es|pt|zh|ja)/(?:login|register|register-doctor|verify-email|verify-mfa|forgot-password|email-verified|callback|doctor-dashboard|pricing|how-it-works|contact|help-center|terms|privacy|cookie-policy)(?:/|$)).*)",
      "has": [
        {
          "type": "host",
          "value": "^(www\\.)?mydoctors360\\.(com|co\\.uk|eu)$"
        }
      ],
      "destination": "/coming-soon/index.html"
    }
  ]
}
